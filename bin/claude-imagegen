#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
DATA_ROOT="${CLAUDE_PLUGIN_DATA:-${XDG_DATA_HOME:-${HOME:-${PLUGIN_ROOT}/.claude-imagegen-data}/.local/share}/claude-imagegen}"
VENV_DIR="${CLAUDE_IMAGEGEN_VENV:-${DATA_ROOT}/venv}"
BOOTSTRAP="${CLAUDE_IMAGEGEN_BOOTSTRAP:-1}"

deps_available() {
  "$1" - <<'PY' >/dev/null 2>&1
import numpy
import PIL
PY
}

PYTHON="python3"

if ! deps_available "$PYTHON"; then
  if [[ "$BOOTSTRAP" == "0" ]]; then
    echo "claude-imagegen requires numpy and Pillow. Install this package or unset CLAUDE_IMAGEGEN_BOOTSTRAP=0." >&2
    exit 1
  fi

  mkdir -p "$DATA_ROOT"

  if [[ ! -x "$VENV_DIR/bin/python" ]]; then
    python3 -m venv "$VENV_DIR"
  fi

  PYTHON="$VENV_DIR/bin/python"

  if ! deps_available "$PYTHON"; then
    "$PYTHON" -m "pip" install --upgrade pip
    "$PYTHON" -m "pip" install "$PLUGIN_ROOT"
  fi
fi

export PYTHONPATH="${PLUGIN_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"

exec "$PYTHON" -m claude_imagegen.cli "$@"
